  <property name="styleSheet">
   <string notr="true">/* ====== GENERAL ====== */
QDialog {
    background-color: #f5f6fa;
    font-family: &quot;Segoe UI&quot;, &quot;San Francisco&quot;, Arial;
    font-size: 13px;
    color: #2f3640;
}

/* ====== LABELS ====== */
QLabel {
    color: #2f3640;
    font-weight: 500;
}

/* ====== INPUTS ====== */
QLineEdit, QTextEdit {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    border-radius: 10px;
    padding: 6px 8px;
    selection-background-color: #4a90e2;
    selection-color: white;
}

QLineEdit:focus, QTextEdit:focus {
    border: 1px solid #4a90e2;
}

/* Placeholder */
QLineEdit[echoMode=&quot;0&quot;] {
    color: #2f3640;
}

/* ====== BOTONES ====== */
QPushButton {
    background-color: #4a90e2;
    color: white;
    border-radius: 10px;
    padding: 6px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #357ABD;
}

QPushButton:pressed {
    background-color: #2d6bb3;
}

/* Botón secundario (puedes cambiarle objectName si quieres) */
QPushButton#btnBuscar {
    background-color: #dcdde1;
    color: #2f3640;
}

QPushButton#btnBuscar:hover {
    background-color: #c8c9cc;
}

/* ====== SCROLL ====== */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
}

QScrollBar::handle:vertical {
    background: #c8d6e5;
    border-radius: 4px;
}

QScrollBar::handle:vertical:hover {
    background: #4a90e2;
}

/* ====== GROUP BOX (si usas) ====== */
QGroupBox {
    border: 1px solid #dcdde1;
    border-radius: 10px;
    margin-top: 10px;
    padding: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px;
    color: #4a90e2;
    font-weight: bold;
}

/* ====== TOOLTIP ====== */
QToolTip {
    background-color: #2f3640;
    color: white;
    border-radius: 6px;
    padding: 4px;
}</string>
